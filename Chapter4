### Use subqueries in Updates
## case
USE sql_invoicing;

UPDATE invoices
SET 
	payment_total = invoice_total *0.5,
    payment_date = due_date
WHERE client_id IN
			(SELECT client_id
			FROM clients
			WHERE state IN ('CA', 'NY'))

## 课堂练习
