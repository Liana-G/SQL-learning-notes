## 课堂练习
CREATE TABLE invoices_archived AS
SELECT 
	i.invoice_id,
    i.number,
    c.name AS client,
    i.invoice_total,
    i.payment_total,
    i.invoice_date,
    i.payment_date
    
FROM invoices i
JOIN clients c
	USING (client_id)
WHERE payment_date IS NOT NULL


