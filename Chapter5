### Aggregate Functions
## case
USE sql_invoicing;

SELECT 
	  MAX(invoice_total) AS highest,
    MIN(invoice_total) AS lowest,
    AVG(invoice_total) AS averdage,
    SUM(invoice_total) AS total,
    COUNT(payment_date) AS count_of_payments, --计数所有非空值
    COUNT(*) AS count_of_payments --计算所有值
    COUNT(DISTINCT client_id) AS total_records --如何去重计数！
FROM invoices
WHERE invoice_date > '2019-07-01' --可以加上筛选条件

