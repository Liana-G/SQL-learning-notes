FROM invoices i


### Group By
## case--单列 Group By
USE sql_invoicing;
SELECT 
	client_id,
    SUM(invoice_total) AS total_sales
FROM invoices
WHERE invoices_date >= '2019-07-01'
GROUP BY client_id
ORDER BY total_sales DESC --根据总销售额降序排列显示

## case--多列Group By
USE sql_invoicing;
SELECT 
	state,
    city,
    SUM(invoice_total) AS total_sales
FROM invoices i
JOIN clients USING (client_id)
GROUP BY state, city

## 课堂练习
USE sql_invoicing;
SELECT 
	date,
	pm.name AS payment_method,
    SUM(amount) AS total_payments

FROM payments p
JOIN payment_methods pm
	ON p.payment_method = pm.payment_method_id
GROUP BY date, payment_method
ORDER BY date ASC, payment_method ASC --规定第二列的排序，如果没有规定的话，第二列的顺序每次可能展示出来就是随机的。

### HAVING clause
## case
使用Having语法，作为Group By之后的筛选。
USE sql_invoicing;
SELECT 
	client_id,
    SUM(invoice_total) AS total_sales
FROM invoices
GROUP BY client_id
HAVING total_sales > 500 --仅筛选出总销售额大于 500 的数据条

