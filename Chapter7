### IF Function
## case
USE sql_store;

SELECT 
	order_id,
    order_date,
    IF(YEAR(order_date) = YEAR(NOW()) - 7, 'Active', 'Archived') AS status
FROM orders

## 课堂作业
USE sql_store;

SELECT 
	product_id,
    name,
    COUNT(*) AS orders,
    IF(COUNT(*) = 1, 'Once', 'Many times') AS Frequency
FROM products
JOIN order_items USING(product_id)
GROUP BY product_id

### Case operator
## case
USE sql_store;
SELECT
	order_id,
    CASE
		WHEN YEAR(order_date) = YEAR(NOW()) - 7 THEN 'Active'
		WHEN YEAR(order_date) = YEAR(NOW()) - 8 THEN 'Last Year'
		WHEN YEAR(order_date) < YEAR(NOW()) - 8 THEN 'Archived'
		ELSE 'Future'
    END AS category
FROM orders

