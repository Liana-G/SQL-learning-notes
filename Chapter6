### The EXIST operator
## case--之前的方法
-- Select clients that have an invoice

SELECT *
FROM clients
WHERE client_id IN (
	SELECT DISTINCT client_id
    FROM invoices
)

## case--使用EXIST运算符
-- Select clients that have an invoice
--  数据量庞大时，EXIST的处理效率更高（不会返回过程值）
SELECT *
FROM clients c
WHERE EXISTS (
	SELECT client_id
    FROM invoices
    WHERE client_id = c.client_id
)

