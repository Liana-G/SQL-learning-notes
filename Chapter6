### IN 语法
## case
-- Find the products that have never been ordered

USE sql_store;

SELECT *
FROM products
WHERE product_id NOT IN(
	SELECT DISTINCT product_id
	FROM order_items
)

## 课堂练习1
-- Find clients without invoices

USE sql_invoicing;

SELECT *
FROM clients
WHERE client_id NOT IN (
	SELECT DISTINCT client_id 
	FROM invoices
)

-- 用 JOIN 语法重写上面的查询
SELECT *
FROM clients
LEFT JOIN invoices USING ( client_id )
WHERE invoice_id IS NULL

## 课堂练习2
# 使用IN语法
-- Find customers who have ordered lettuce ( id = 3 )
-- Select customer_id, first_name, last_name

USE sql_store;

SELECT customer_id, first_name, last_name
FROM customers
WHERE customer_id IN (
	SELECT customer_id
	FROM orders
	WHERE order_id IN (
		SELECT order_id
		FROM order_items
		WHERE product_id = 3 
))

# 使用JOIN语法
-- Find customers who have ordered lettuce ( id = 3 )
-- Select customer_id, first_name, last_name

USE sql_store;

SELECT DISTINCT customer_id, first_name, last_name
FROM customers c
JOIN orders o USING ( customer_id )
JOIN order_items oi USING ( order_id )
WHERE oi.product_id = 3

### The ALL keyword
## case--常规方法
-- Select invoices larger than all invoices of client 3

USE sql_invoicing;

SELECT *
FROM invoices
WHERE invoice_total > (
	SELECT MAX(invoice_total)
	FROM invoices
	WHERE client_id = 3
)

# case--使用 ALL 关键词解决问题
-- Select invoices larger than all invoices of client 3

USE sql_invoicing;

SELECT *
FROM invoices
WHERE invoice_total > ALL (
	SELECT invoice_total
	FROM invoices
	WHERE client_id = 3
)

### Any keyword
## case
any 用法同 all。含义 All 代表并且，any 代表或者。
-- SELECT clients with at least two invoices

SELECT *
FROM clients
WHERE client_id IN (
	SELECT client_id
	FROM invoices
	GROUP BY client_id
	HAVING COUNT(*) >= 2
)

使用 ANY 语法
-- SELECT clients with at least two invoices

SELECT *
FROM clients
WHERE client_id = ANY(
	SELECT client_id
	FROM invoices
	GROUP BY client_id
	HAVING COUNT(*) >= 2
)

### 相关子查询 Correlated Subqueries
-- Select employees whose salary is above the average in their office
--  伪代码 pseudo code:先计算每个员工所在 office 的平均薪资，然后比较每个员工薪资与其对应平均薪资

SELECT *
FROM employees e
WHERE salary > (
SELECT AVG(salary) AS avg_salary
FROM emplyees
WHERE office_id = e.office_id
)

